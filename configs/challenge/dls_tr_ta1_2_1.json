        "d_model":      128,
        "nhead":        4,
        "num_layers":   1,
        "embed":        "lin"
    },

    "train": {
        "train_split":  0.8,
        "test_split":   0.1,
        "sample_train": 0,
        "sample_test":  0,
        "lr":           0.001,
        "num_epochs":   200,
        "patience":     200,
        "train_ahead":  1,
        "batch_size":   128,
        "gamma":        1
    },

    "predictions": {
        "validation": {
            "init":     "val",
            "lim":      null
        },
        "seen": {
            "init":     "train",
            "lim":      null
        }
    }
}
